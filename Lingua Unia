```react
import React, { useState, useEffect, useRef } from 'react';
import { 
  Languages, 
  Send, 
  Book, 
  Info, 
  Settings, 
  ChevronRight, 
  Clipboard, 
  Loader2,
  HelpCircle
} from 'lucide-react';

// --- 配置与常量 ---
const API_KEY = ""; // 运行时环境提供
const MODEL_NAME = "gemini-2.5-flash-preview-09-2025";
const APP_ID = typeof __app_id !== 'undefined' ? __app_id : 'lingua-unia-translator';

// --- 系统提示词 (基于上传文档构建) ---
const SYSTEM_PROMPT = `
你是一个专业的 Lingua Unia 语言翻译官和专家。
Lingua Unia 是一种逻辑透明型国际人造语言。

你的任务：
1. 将用户输入的自然语言（中文或英文）准确地翻译成 Lingua Unia。
2. 翻译必须严格遵守《Lingua Unia 设计规范》：
   - 名词后缀 -as, 动词 -is, 形容词 -a, 副词 -e。
   - 动词及物性标记：二元动词必须加 -t (例如 vidi-is-t tu-n)。
   - 宾格标记 -n。
   - 语序 SVO。
   - 借词后缀规则 (如 -eng, -cin, -lat)。
3. 提供简洁的语法分析，解释翻译中用到的词根和逻辑。

核心词根参考：
- 人: homa, 我: mi, 你: tu, 他: lu
- 是: ese, 过去时助词: temi, 将来时: temo
- 好的: bon, 坏的: mal-bon
- 逻辑连接词: an (和), sed (但), car (因为), do (所以)

输出格式要求：
{
  "translation": "Lingua Unia 译文",
  "analysis": "简要的语法点拨",
  "vocabulary": [{"root": "词根", "meaning": "含义"}]
}
请始终返回有效的 JSON 格式。
`;

const App = () => {
  const [inputText, setInputText] = useState('');
  const [result, setResult] = useState(null);
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState(null);
  const [activeTab, setActiveTab] = useState('translator');

  // 指数退避重试机制
  const fetchWithRetry = async (prompt, retries = 5, delay = 1000) => {
    try {
      const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/${MODEL_NAME}:generateContent?key=${API_KEY}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          contents: [{ parts: [{ text: prompt }] }],
          systemInstruction: { parts: [{ text: SYSTEM_PROMPT }] },
          generationConfig: {
            responseMimeType: "application/json",
            responseSchema: {
              type: "OBJECT",
              properties: {
                translation: { type: "STRING" },
                analysis: { type: "STRING" },
                vocabulary: {
                  type: "ARRAY",
                  items: {
                    type: "OBJECT",
                    properties: {
                      root: { type: "STRING" },
                      meaning: { type: "STRING" }
                    }
                  }
                }
              }
            }
          }
        })
      });

      if (!response.ok) throw new Error(`HTTP Error: ${response.status}`);
      return await response.json();
    } catch (err) {
      if (retries > 0) {
        await new Promise(res => setTimeout(res, delay));
        return fetchWithRetry(prompt, retries - 1, delay * 2);
      }
      throw err;
    }
  };

  const handleTranslate = async () => {
    if (!inputText.trim()) return;
    setLoading(true);
    setError(null);
    try {
      const data = await fetchWithRetry(inputText);
      const parsedContent = JSON.parse(data.candidates[0].content.parts[0].text);
      setResult(parsedContent);
    } catch (err) {
      setError("翻译失败，请检查网络或稍后重试。");
    } finally {
      setLoading(false);
    }
  };

  const copyToClipboard = (text) => {
    const el = document.createElement('textarea');
    el.value = text;
    document.body.appendChild(el);
    el.select();
    document.execCommand('copy');
    document.body.removeChild(el);
  };

  return (
    <div className="min-h-screen bg-slate-50 text-slate-900 font-sans">
      {/* 顶部导航 */}
      <nav className="bg-white border-b border-slate-200 px-6 py-4 flex items-center justify-between sticky top-0 z-10">
        <div className="flex items-center gap-2">
          <div className="bg-indigo-600 p-2 rounded-lg">
            <Languages className="text-white w-6 h-6" />
          </div>
          <div>
            <h1 className="text-xl font-bold tracking-tight">Lingua Unia</h1>
            <p className="text-xs text-slate-500 font-medium uppercase tracking-widest">逻辑透明型国际语</p>
          </div>
        </div>
        <div className="flex gap-4">
          <button 
            onClick={() => setActiveTab('translator')}
            className={`px-3 py-1 rounded-md text-sm font-medium transition ${activeTab === 'translator' ? 'bg-indigo-100 text-indigo-700' : 'text-slate-600 hover:bg-slate-100'}`}
          >
            翻译
          </button>
          <button 
            onClick={() => setActiveTab('dictionary')}
            className={`px-3 py-1 rounded-md text-sm font-medium transition ${activeTab === 'dictionary' ? 'bg-indigo-100 text-indigo-700' : 'text-slate-600 hover:bg-slate-100'}`}
          >
            字典
          </button>
        </div>
      </nav>

      <main className="max-w-4xl mx-auto p-6">
        {activeTab === 'translator' ? (
          <div className="space-y-6">
            {/* 输入区 */}
            <div className="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden transition-all hover:shadow-md">
              <div className="p-4 border-b border-slate-100 flex items-center justify-between bg-slate-50/50">
                <span className="text-xs font-bold text-slate-500 uppercase">源语言 (中/英)</span>
                <div className="flex gap-2">
                  <button onClick={() => setInputText('')} className="text-xs text-slate-400 hover:text-slate-600">清空</button>
                </div>
              </div>
              <textarea 
                className="w-full p-5 text-lg border-none focus:ring-0 min-h-[140px] resize-none"
                placeholder="输入想要翻译的句子..."
                value={inputText}
                onChange={(e) => setInputText(e.target.value)}
              />
              <div className="p-4 flex justify-end">
                <button 
                  onClick={handleTranslate}
                  disabled={loading || !inputText}
                  className="bg-indigo-600 hover:bg-indigo-700 disabled:bg-slate-300 text-white px-6 py-2.5 rounded-xl font-bold flex items-center gap-2 transition-transform active:scale-95 shadow-lg shadow-indigo-200"
                >
                  {loading ? <Loader2 className="w-5 h-5 animate-spin" /> : <Send className="w-5 h-5" />}
                  执行翻译
                </button>
              </div>
            </div>

            {/* 错误提示 */}
            {error && (
              <div className="bg-red-50 border border-red-100 text-red-600 p-4 rounded-xl flex items-start gap-3">
                <Info className="w-5 h-5 mt-0.5 flex-shrink-0" />
                <p className="text-sm font-medium">{error}</p>
              </div>
            )}

            {/* 结果显示 */}
            {result && (
              <div className="animate-in fade-in slide-in-from-bottom-4 duration-500 space-y-6">
                {/* 译文主体 */}
                <div className="bg-gradient-to-br from-indigo-600 to-violet-700 rounded-2xl p-6 text-white shadow-xl">
                  <div className="flex justify-between items-start mb-4">
                    <span className="text-xs font-bold text-indigo-100 uppercase tracking-widest">Lingua Unia 译文</span>
                    <button 
                      onClick={() => copyToClipboard(result.translation)}
                      className="p-2 hover:bg-white/10 rounded-lg transition"
                    >
                      <Clipboard className="w-5 h-5" />
                    </button>
                  </div>
                  <p className="text-2xl font-medium leading-relaxed tracking-wide">
                    {result.translation}
                  </p>
                </div>

                <div className="grid md:grid-cols-2 gap-6">
                  {/* 语法解析 */}
                  <div className="bg-white rounded-2xl p-6 border border-slate-200 shadow-sm">
                    <div className="flex items-center gap-2 mb-4 text-indigo-600">
                      <Book className="w-5 h-5" />
                      <h3 className="font-bold">语法逻辑分析</h3>
                    </div>
                    <p className="text-slate-600 text-sm leading-relaxed whitespace-pre-wrap">
                      {result.analysis}
                    </p>
                  </div>

                  {/* 词汇表 */}
                  <div className="bg-white rounded-2xl p-6 border border-slate-200 shadow-sm">
                    <div className="flex items-center gap-2 mb-4 text-emerald-600">
                      <HelpCircle className="w-5 h-5" />
                      <h3 className="font-bold">核心词汇对照</h3>
                    </div>
                    <div className="space-y-2">
                      {result.vocabulary.map((item, idx) => (
                        <div key={idx} className="flex items-center justify-between p-2 rounded-lg bg-slate-50 hover:bg-slate-100 transition">
                          <span className="font-mono font-bold text-indigo-600">{item.root}</span>
                          <ChevronRight className="w-4 h-4 text-slate-300" />
                          <span className="text-sm text-slate-600 font-medium">{item.meaning}</span>
                        </div>
                      ))}
                    </div>
                  </div>
                </div>
              </div>
            )}
            
            {/* 引导说明 */}
            {!result && !loading && (
              <div className="text-center py-12 px-6">
                <div className="bg-slate-100 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4">
                  <Languages className="text-slate-400 w-8 h-8" />
                </div>
                <h3 className="text-lg font-bold text-slate-700">开始探索 Lingua Unia</h3>
                <p className="text-slate-500 max-w-sm mx-auto mt-2">
                  输入诸如“我想学习人工智能”或“道可道，非常道”试试看。
                </p>
              </div>
            )}
          </div>
        ) : (
          <div className="bg-white rounded-2xl shadow-sm border border-slate-200 p-8 text-center">
            <h2 className="text-2xl font-bold mb-4">Lingua Unia 核心规范预览</h2>
            <p className="text-slate-600 mb-8">在这里你可以快速回顾语言的关键逻辑。完整规范请参考上传的文档。</p>
            <div className="grid grid-cols-2 md:grid-cols-4 gap-4 text-left">
              <div className="p-4 bg-slate-50 rounded-xl border border-slate-100">
                <div className="text-xs font-bold text-slate-400 mb-1">名词后缀</div>
                <div className="text-lg font-mono text-indigo-600">-as</div>
              </div>
              <div className="p-4 bg-slate-50 rounded-xl border border-slate-100">
                <div className="text-xs font-bold text-slate-400 mb-1">动词后缀</div>
                <div className="text-lg font-mono text-indigo-600">-is</div>
              </div>
              <div className="p-4 bg-slate-50 rounded-xl border border-slate-100">
                <div className="text-xs font-bold text-slate-400 mb-1">形容词后缀</div>
                <div className="text-lg font-mono text-indigo-600">-a</div>
              </div>
              <div className="p-4 bg-slate-50 rounded-xl border border-slate-100">
                <div className="text-xs font-bold text-slate-400 mb-1">及物标记</div>
                <div className="text-lg font-mono text-indigo-600">-t</div>
              </div>
            </div>
            <div className="mt-8 p-6 bg-amber-50 border border-amber-100 rounded-2xl text-left">
              <h4 className="font-bold text-amber-800 mb-2">💡 设计师笔记</h4>
              <p className="text-sm text-amber-700 leading-relaxed">
                Lingua Unia 强调“一词一义”。每个动词在及物使用时必须明确标记宾格 -n。这种透明性确保了翻译在逻辑上是百分之百还原的。
              </p>
            </div>
          </div>
        )}
      </main>
      
      {/* 底部装饰 */}
      <footer className="max-w-4xl mx-auto px-6 py-12 text-center text-slate-400 text-xs">
        &copy; 2025 Lingua Unia Project - 基于逻辑透明性的未来语言
      </footer>
    </div>
  );
};

export default App;

```
